# ====== 培养基 环境变量配置 ======
# 将此文件复制为 .env 并填入真实密钥
# cp .env.example .env
#
# 生产环境部署：直接在服务器系统环境变量中配置这些变量，
# 无需 .env 文件（dotenv 会优雅降级到 process.env）

# ====== MiniMax API（必填）======
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com
MINIMAX_API_HOST=https://api.minimaxi.com

# ====== 阿里云百炼（可选，USE_BAILIAN=true 时需要）======
# BAILIAN_API_KEY=your_bailian_api_key_here
# BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ====== 模型切换 ======
# true=使用百炼/qwen-max，false=使用 MiniMax M2.7
USE_BAILIAN=false

# ====== 管理员配置 ======
# 管理员用户 ID，逗号分隔多个。默认为 id=1（第一个注册用户）
# ADMIN_UID=1

# ====== JWT 密钥 ======
# 生产环境请务必修改此值！
# JWT_SECRET=请替换为随机字符串

# ====== Qdrant 向量数据库（可选）======
# QDRANT_URL=http://127.0.0.1:6333
